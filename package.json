{
  "name": "virtuoso",
  "version": "0.0.1",
  "description": "A virtual machine host for Discord powered by VMware.",
  "main": "./src/main.ts",
  "scripts": {
    "preinstall": "npx npm-force-resolutions",
    "start": "pm2 start ./dist/src/main.js -n virtuoso -i 1 --wait-ready --shutdown-with-message --max-restarts=1",
    "start:no-pm2": "node ./dist/src/main.js",
    "build": "tsc --build",
    "clean": "rimraf ./dist/",
    "dev": "tsc --watch",
    "lint": "eslint src --ext ts",
    "lint:fix": "eslint src --ext ts --fix",
    "test": "snyk test && pm2 trigger virtuoso test-bot"
  },
  "author": "obfuscatedgenerated",
  "repository": {
    "type": "git",
    "url": "git://github.com/obfuscatedgenerated/Virtuoso.git"
  },
  "private": true,
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.8.0",
    "discord.js-rate-limiter": "^1.3.2",
    "npm-force-resolutions": "^0.0.10",
    "pm2": "^5.2.0",
    "rimraf": "^4.4.0",
    "source-map-support": "^0.5.21",
    "tx2": "^1.0.5",
    "uuid": "^9.0.0",
    "vmrun": "github:obfuscatedgenerated/node-vmrun"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^5.56.0",
    "@typescript-eslint/parser": "^5.56.0",
    "eslint": "^8.36.0",
    "snyk": "^1.1297.3",
    "typescript": "^5.0.2"
  },
  "engines": {
    "node": ">=16.9.0"
  }
}
