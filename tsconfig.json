{
    "compilerOptions": {
      "noImplicitAny": false,
      "noEmitOnError": true,
      "removeComments": true,
      "inlineSourceMap": true,
      "target": "es5",
      "outDir": "dist",
      "typeRoots": ["./declarations", "./node_modules/@types"],
      "types": ["node"],
      "skipLibCheck": true,
      "resolveJsonModule": true,
    },
    "include": [
      "src/**/*",
      "src/**/*.json",
    ]
  }